# Server
NODE_ENV=development
PORT=3001

# Frontend
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/thronos_realestate

# Blockchain
THRONOSCHAIN_RPC=http://localhost:8545
THRONOSCHAIN_PRIVATE_KEY=0x...
PROPERTY_CONTRACT_ADDRESS=0x...

# KYC/AML Services
KYC_PROVIDER=stripe # or idology, jumio, etc
STRIPE_API_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@thronos.io
SMTP_PASSWORD=...

# Logging
LOG_LEVEL=info

# API Keys
JWT_SECRET=your-super-secret-jwt-key
API_KEY_PREFIX=sk_thronos_
