# ---------------------------------------------------------------
# ThronomedICE - Temperature Monitoring Service
# Copy to .env and fill in real values before starting.
# ---------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://medice:medice@localhost:5432/medicedb

# Thronos blockchain RPC endpoint
THRONOS_RPC_URL=http://localhost:8545

# Private key of the service wallet that writes to the chain
# (fund this wallet with enough THRON for gas)
MEDICE_PRIVATE_KEY=0x_YOUR_SERVICE_WALLET_PRIVATE_KEY

# Address of the deployed FeverHistory.sol contract
# Run contracts/deploy.py to get this value
FEVER_CONTRACT_ADDRESS=0x_YOUR_CONTRACT_ADDRESS

# Firebase Cloud Messaging server key (for push notifications to Android)
# For iOS use APNs credentials instead
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY

# Secret API key that hospital systems must send in X-Hospital-Key header
HOSPITAL_API_KEY=change_me_to_a_long_random_string
